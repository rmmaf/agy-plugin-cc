{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "plugins/agy/scripts/lib/agy.mjs",
    "plugins/agy/scripts/lib/fs.mjs",
    "plugins/agy/scripts/lib/process.mjs"
  ]
}
